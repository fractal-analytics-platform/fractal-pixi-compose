# fractal-server configuration
# Read automatically by fractal-server from the working directory.
# See: https://fractal-analytics-platform.github.io/fractal-server/configuration/

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=fractaldb
POSTGRES_HOST=localhost
POSTGRES_USER=fractal
POSTGRES_PASSWORD=fractal
# Leave POSTGRES_USER / POSTGRES_PASSWORD unset to authenticate as the current
# Unix user (matches the trust-auth cluster created by `pixi run setup`).

# ─── Security ─────────────────────────────────────────────────────────────────
# Change this to a long random string before exposing the server to a network.
JWT_SECRET_KEY=local-dev-secret-change-me

# ─── Runner ───────────────────────────────────────────────────────────────────
FRACTAL_RUNNER_BACKEND=local

# ─── User groups ──────────────────────────────────────────────────────────────
# "All" is a special built-in group; new users are added to it automatically.
FRACTAL_DEFAULT_GROUP_NAME=All

# ─── Token lifetime ───────────────────────────────────────────────────────────
JWT_EXPIRE_SECONDS=84600

# ─── Logging ──────────────────────────────────────────────────────────────────
# 10=DEBUG, 20=INFO, 30=WARNING
FRACTAL_LOGGING_LEVEL=20
