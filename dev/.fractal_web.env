# fractal-web configuration
# Loaded by: node --env-file=.fractal_web.env .fractal-web/build/
# See: https://fractal-analytics-platform.github.io/fractal-web/quickstart/

# URL of the fractal-server backend
FRACTAL_SERVER_HOST=http://127.0.0.1:8000

# Runner backend (must match fractal-server's FRACTAL_RUNNER_BACKEND setting)
FRACTAL_RUNNER_BACKEND=local

# Origin of this web app (used for CSRF protection)
ORIGIN=http://localhost:5173

# Port to listen on
PORT=5173

# Cookie domain for authentication
AUTH_COOKIE_DOMAIN=localhost

# Required for HTTP (non-HTTPS) local dev; set to true when behind TLS
AUTH_COOKIE_SECURE=false

# Must match FRACTAL_DEFAULT_GROUP_NAME in .fractal_server.env
FRACTAL_DEFAULT_GROUP_NAME=All

# Admin support email shown in the UI
PUBLIC_FRACTAL_ADMIN_SUPPORT_EMAIL=admin@localhost

# Max request body size in bytes (5 MB)
BODY_SIZE_LIMIT=5000000
